let THEME_NAMES = [
    "dark", "dracula", "nord", "light", 
    "solarized_dark", "solarized_light", 
    "monokai", "gruvbox", "one_dark"
]

fn get_theme(name: string) -> Theme {
    THEMES[name].unwrap_or(THEMES["dark"])
}

fn get_theme_names() -> list<string> {
    THEME_NAMES
}