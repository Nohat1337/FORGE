// Theme Module

struct Theme {
    name: string
    editor_bg: int
    editor_fg: int
    gutter_bg: int
    gutter_fg: int
    gutter_current_bg: int
    gutter_current_fg: int
    selection_bg: int
    cursor_bg: int
    cursor_fg: int
    line_current_bg: int
    
    menu_bg: int
    menu_fg: int
    menu_sel_bg: int
    menu_sel_fg: int
    
    status_bg: int
    status_fg: int
    
    panel_bg: int
    panel_fg: int
    panel_border: int
    
    accent1: int
    accent2: int
    accent3: int
    accent4: int
    accent5: int
    accent6: int
    
    keyword_control: int
    keyword_decl: int
    keyword_other: int
    string: int
    string_interp: int
    number: int
    comment: int
    operator: int
    function: int
    builtin: int
    type: int
    variable: int
    punctuation: int
    preproc: int
    error: int
}

