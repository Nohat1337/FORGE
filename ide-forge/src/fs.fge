fn is_absolute(path: string) -> bool {
    path.starts_with("/") || (path.len() >= 3 && path[1] == ':' && path[2] == '\\')
}

fn join(a: string, b: string) -> string {
    if a.ends_with("/") { a + b } else { a + "/" + b }
}

fn parent(path: string) -> string {
    let i = path.rfind('/')
    if i == -1 { "." } else { path.substr(0, i) }
}

fn filename(path: string) -> string {
    let i = path.rfind('/')
    if i == -1 { path } else { path.substr(i + 1) }
}

fn extension(path: string) -> string {
    let i = path.rfind('.')
    let j = path.rfind('/')
    if i == -1 || (j != -1 && i < j) { "" } else { path.substr(i + 1) }
}

fn stem(path: string) -> string {
    let name = filename(path)
    let i = name.rfind('.')
    if i == -1 { name } else { name.substr(0, i) }
}

fn normalize(path: string) -> string {
    let parts = path.split('/')
    let mut result = []
    for part in parts {
        if part == "" || part == "." { continue }
        if part == ".." {
            if !result.is_empty() { result.pop() }
        } else {
            result.push(part)
        }
    }
    if path.starts_with("/") {
        "/" + result.join("/")
    } else {
        result.join("/")
    }
}