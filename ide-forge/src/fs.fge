}

fn cwd() -> string {
    os.cwd()
}

fn set_cwd(path: string) -> Result<(), string> {
    os.chdir(path)
}

struct DirEntry {
    name: string
    path: string
    is_dir: bool
    size: int
    modified: float
}

fn list_dir(path: string) -> list<DirEntry> {
    let entries = read_dir(path)
    if entries.is_err() { return [] }
    let result = []
    for e in entries.unwrap() {
        let full = path + "/" + e.name
        let meta = os.metadata(full)
        result.push(DirEntry {
            name: e.name,
            path: full,
            is_dir: e.is_dir,
            size: meta.size,
            modified: meta.modified
        })
    }
    result
}

fn find_files(root: string, pattern: string) -> list<string> {
    let result = []
    fn walk(dir: string) {
        let entries = list_dir(dir)
        for e in e {
            let full = dir + "/" + e.name
            if e.is_dir {
                walk(full)
            } else if e.name.contains(pattern) {
                result.push(full)
            }
        }
    }
    walk(root)
    result
}

fn glob(pattern: string) -> list<string> {
    // Simple glob implementation
    let parts = pattern.split('/')
    let mut results = [""]
    for part in parts {
        let mut new_results = []
        if part.contains('*') || part.contains('?') {
            for base in results {
                let dir = if base == "" { "." } else { base }
                let entries = list_dir(dir)
                for e in entries {
                    let full = if base == "" { e.name } else { base + "/" + e.name }
                    if match_glob(e.name, part) {
                        new_results.push(full)
                    }
                }
            }
            results = new_results
        } else {
            for base in results {
                results.push(base + "/" + part)
            }
        }
    }
    results
}

fn match_glob(name: string, pattern: string) -> bool {
    // Simple glob matching
    let mut i = 0
    let mut j = 0
    let mut star_i = -1
    let mut star_j = -1
    
    while i < name.len() {
        if j < pattern.len() && (pattern[j] == name[i] || pattern[j] == '?') {
            i++
            j++
        } else if j < pattern.len() && pattern[j] == '*' {
            star_i = i
            star_j = j
            j++
        } else if star_j != -1 {
            j = star_j + 1
            star_i++
            i = star_i
        } else {
            return false
        }
    }
    
    while j < pattern.len() && pattern[j] == '*' {
        j++
    }
    
    j == pattern.len()
}

